http {
    # Определяем зону для rate limiting: по IP клиента, размер зоны 10МБ, скорость 10 запросов в минуту
    limit_req_zone $binary_remote_addr zone=ratelimit:10m rate=10r/m;
    # При превышении лимита возвращаем HTTP 429 Too Many Requests
    limit_req_status 429;

    upstream backend_servers {
        server backend1.example.com;
        server backend2.example.com;
        server backend3.example.com;
    }

    server {
        listen 80;

        location / {
            # Применяем ограничение к данному location
            limit_req zone=ratelimit;
            proxy_pass http://backend_servers;
        }
    }
}
